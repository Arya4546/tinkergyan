{
  "name": "@tinkergyan/eslint-config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./base": "./base.js",
    "./node": "./node.js",
    "./react": "./react.js"
  },
  "scripts": {
    "format": "prettier --check \"*.{js,cjs,mjs,ts}\" --ignore-path ../../.prettierignore",
