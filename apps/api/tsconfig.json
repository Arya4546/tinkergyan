{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "paths": {
      "@/*": ["src/*"]
    },
    "rootDir": ".",
    "target": "ES2022"
  },
  "include": ["src/**/*.d.ts", "src/**/*.ts", "prisma/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
