# DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/tinkergyan?schema=public"

# AUTH
JWT_SECRET="generate-a-32-character-random-string-here"
JWT_EXPIRES_IN="7d"

# SERVER
PORT=3001
NODE_ENV=development

# REDIS (Optional for Phase 1)
# REDIS_URL="redis://localhost:6379"

# CORS / FRONTEND
FRONTEND_URL="http://localhost:5173"

# SANDBOX (Phase 2)
MAX_COMPILE_TIMEOUT=30000
COMPILE_CONCURRENCY=5
